// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Activite {
  id           Int       @id @default(autoincrement())
  nom          String
  type         String    @default("ponctuelle")
  dateActivite DateTime?
  heure        String?
  lieu         String    @default("Temple MEMFA")
  objectif     String?
  participants String    @default("Toute la jeunesse")
  preparation  String?
  statut       String    @default("a_venir")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  rappels      RappelLog[]

  @@map("activites")
}

model RappelLog {
  id            Int      @id @default(autoincrement())
  activiteId    Int
  joursRestants Int
  message       String
  mode          String   @default("manuel")
  envoyeLe      DateTime @default(now())
  activite      Activite @relation(fields: [activiteId], references: [id], onDelete: Cascade)

  @@map("rappel_logs")
}